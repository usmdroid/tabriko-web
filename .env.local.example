# Public API base URL (default used if not set)
NEXT_PUBLIC_API_BASE=https://api.tabriko.uz/api/v1

# Sentry DSN for error tracking (optional, leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# App Store / Google Play links
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/tabriko
NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=uz.tabriko
